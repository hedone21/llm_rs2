          "level": "critical",
          "available_bytes": 30000000,
          "reclaim_target_bytes": 100000000
        }
      }
    },
    {
      "at_token": 768,
      "signal": {
        "memory_pressure": {
          "level": "normal",
          "available_bytes": 500000000,
          "reclaim_target_bytes": 0
