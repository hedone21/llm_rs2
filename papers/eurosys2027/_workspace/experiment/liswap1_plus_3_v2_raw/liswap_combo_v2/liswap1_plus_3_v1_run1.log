#
# Script to turn a list of sentences into single string where each sentence is separated by a new line character.
#

def main():
    # Read sentences file one line at a time. The sentences are saved as strings, and not lists.
    with open("sentences.txt", "r") as f:
        for line in f.readlines():
            print(line.rstrip())

if __name__ == "__main__":
    main()#!/usr/bin/env python3
