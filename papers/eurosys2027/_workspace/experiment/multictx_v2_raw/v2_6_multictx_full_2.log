# Return True if all the reversed words are same as original, False otherwise.
def is_palindrome(sentence):
  sentence = sentence.lower()
  return all(word == reverse_word for (word, reverse_word) in zip(sentence.split(),reversed([x for x in sentence.split()])))

print(is_palindrome("The quick brown fox jumps over the lazy dog."))
