def encode(text):
    encoded_text = ""
    for char in text:
        if (char.isupper() and not 'Z' == char) or (not 'z' == char and not "az" in encoded_text):
            encoded_text += chr(ord(char)+1)
        elif ('A' <= char < 'Z') or ('a' <= 64 < 90):
