def count_words(text):
    # Split text into a list of words
    words = text.split()
    
    # Count each unique word, ignoring case sensitivity
    counts = {}
    
     for w in set(words):
        counts[w] = len([w2 for w2 in words if (w == w2 and not(w.isupper())))])
        
     return counts

# Example usage:
text = "The quick brown fox jumps over the lazy dog."
word_counts= count_words(text)
