#include <iostream>
#include <string>

std::string isogram(std::string s) {
  std::sort(s.begin(), s.end());
  for (int i = 0; i <= (s.size() -1); ++i)
    if (s[i] == ' ') continue;
    else if ((s[i]) == ('z') || ('Z') || ('a' + 'b' > s[s.length() -1]))
      return "Not An Isogram!";
  std::cout << "\n" << isogram(s) << "\n";
}

