# Output: {'the':2, 'quick':1, 'brown':1, 'fox' : 4,'jumps':'3','over':'2','lazy':'3', 'dog.' : 5}# The quick brown fox jumps over the lazy dog.
def word_count(string):
    words = string.split()
    counts = {}
    
    for word in words:
        if word not in counts:
            counts[word] = 1
        else:
            counts[word] += 1
            
            
        
   
        
word_count("The quick brown fox jumps over the lazy dog.")
