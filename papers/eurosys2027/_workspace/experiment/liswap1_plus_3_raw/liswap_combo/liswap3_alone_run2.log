public class Solution {
    public static String solution(String sentence) {
        // Complete the method here
        String[] words = sentence.split(" ");
        
        StringBuilder sb = new StringBuilder();
        
         for (String word : words) { // for every string in array append to s b - (to have one single line)
            sb.append(word.trim()).append(" ");  //
            
         }
         
        return sb.toString().trim(); // trim() - removes white spaces
    }
