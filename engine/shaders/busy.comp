#version 450
layout(local_size_x = 1024) in;
layout(std430, binding = 0) buffer Out { float data[]; };
layout(push_constant) uniform PC { int iters; } pc;
void main() {
    uint id = gl_GlobalInvocationID.x;
    float v = float(id);
    for (int i = 0; i < pc.iters; i++) {
        v = v * 1.00001 + 0.5;
        v -= 0.5;
    }
    data[id] = v;
}
